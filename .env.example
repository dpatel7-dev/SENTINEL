# Copy this file to .env  (command:  cp .env.example .env)  then paste your real keys below.
# Never commit the real .env to GitHub — .gitignore already blocks it.

# 1) Free key from https://finnhub.io  (quotes + news, 60 calls/min)
FINNHUB_API_KEY=paste_your_finnhub_key_here

# 2) Free key from https://www.alphavantage.co/support/#api-key  (market movers, 25 calls/day)
ALPHAVANTAGE_API_KEY=paste_your_alphavantage_key_here

# 3) Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=paste_your_discord_webhook_url_here

# 4) Alpaca PAPER trading keys (see README Part 2 — must come from the Paper dashboard).
#    Sentinel is hardcoded to the paper environment; these keys move simulated money only.
ALPACA_API_KEY=paste_your_alpaca_paper_key_here
ALPACA_SECRET_KEY=paste_your_alpaca_paper_secret_here

PORT=3000
